# Public server settings
KUMOBACKUP_DOMAIN=localhost
KUMOBACKUP_PUBLIC_URL=http://localhost/kumobackup

# Host ports
HTTP_PORT=80
HTTPS_PORT=8443

# ASP.NET
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080
APP_PORT=8080

# PostgreSQL
POSTGRES_DB=kumobackup
POSTGRES_USER=kumobackup
POSTGRES_PASSWORD=kumobackup-dev
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Storage
STORAGE_PATH=/storage
HOST_STORAGE_PATH=./storage
HOST_POSTGRES_PATH=./postgres

# Backup limits
BACKUP_MAX_UPLOAD_BYTES=104857600
NGINX_CLIENT_MAX_BODY_SIZE=100M

# Nginx Basic Auth
NGINX_HTPASSWD_PATH=./nginx/.htpasswd.local

# Certbot / Let's Encrypt
CERTBOT_EMAIL=admin@example.com
CERTBOT_WEBROOT=/var/www/certbot
